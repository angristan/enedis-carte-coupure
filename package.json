{
  "name": "enedis-carte-coupure",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "packageManager": "bun@1.3.9",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "bun run test && bun run typecheck && vite build",
    "build:redirect": "tsc --project tsconfig.redirect.json",
    "preview": "vite preview --host 127.0.0.1",
    "deploy": "bun run build && wrangler deploy --config web/enedis_carte_coupure/wrangler.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "effect": "^4.0.0-beta.97",
    "lucide-react": "1.21.0",
    "maplibre-gl": "5.24.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-map-gl": "8.1.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.4",
    "@cloudflare/workers-types": "^4.20260630.1",
    "@effect/vitest": "^4.0.0-beta.97",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "typescript": "^7.0.2",
    "vite": "8.1.0",
    "vitest": "^4.1.9",
    "wrangler": "^4.106.0"
  }
}
